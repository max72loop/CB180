# Copier ce fichier en .env.local (jamais commité) et renseigner les valeurs.
# Voir SETUP_TURSO.md pour créer la base et générer le token, et DEPLOY.md pour Vercel.

# Base de données Turso (analytics/audits). Optionnel en local : sans elle, le
# site fonctionne mais ne persiste ni audits, ni emails, ni events.
TURSO_DATABASE_URL=libsql://cb180-xxxxx.turso.io
TURSO_AUTH_TOKEN=ton_token_ici

# Clé d'accès à la page admin /stats (choisis une valeur difficile à deviner).
ADMIN_KEY=change_moi

# URL publique du site, utilisée pour les URLs canoniques, le sitemap et les
# images Open Graph. En prod : le vrai domaine (ex. https://cb180.fr).
NEXT_PUBLIC_SITE_URL=https://cb180.fr

# Envoi de l'email de résultat (Resend). Optionnel : sans ces variables, l'email
# est enregistré mais pas envoyé, et l'UI adapte son message.
# RESEND_FROM doit utiliser un domaine vérifié dans Resend.
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=CB180 <resultats@ton-domaine.fr>
